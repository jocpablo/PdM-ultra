# ═══════════════════════════════════════════════════════════════
#  Suite PdM — Variables de Entorno
#  Copia este archivo como .env y ajusta los valores
# ═══════════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_DATABASE=edwards_pdm_db
DB_PORT=5432

# ── Admin Sistema (superusuario único, no se crea en la BD) ────
APP_USER=admin
APP_PASSWORD=pdm2026

# ── Seguridad JWT ───────────────────────────────────────────────
# Cambia este valor en producción por una cadena aleatoria de 64+ caracteres
JWT_SECRET=pdm_edwards_jwt_2026_cambia_esto_en_produccion

# ── Puerto del servidor ─────────────────────────────────────────
PORT=3000

# ── Respaldos ───────────────────────────────────────────────────
BACKUP_DIR=C:\Respaldos\PDM
PG_BIN=C:\Program Files\PostgreSQL\16\bin

# ── Módulos opcionales (true/false) ─────────────────────────────
# Órdenes de Trabajo internas (desactivar si usas Maximo u otro CMMS externo)
MODULO_OT=true

# Sistema de Lubricación y PM Preventivo
MODULO_LUBRICACION=true

# Notificaciones internas en tiempo real (SSE)
MODULO_NOTIFICACIONES=true

# Histórico de KPIs mensuales
MODULO_KPI_HISTORICO=true
